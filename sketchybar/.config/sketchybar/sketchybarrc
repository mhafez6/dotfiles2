#!/bin/bash

# ── Gruvbox Dark — exact palette ─────────────────────────
BG=0xff282828
FG=0xffebdbb2        # cream — primary text
GRAY=0xff928374      # neutral gray — inactive/dim text
YELLOW=0xfffabd2f   # bright yellow (less amber than d79921)
GREEN=0xffb8bb26
RED=0xfffb4934
SPACE_DIM=0x22ebdbb2  # very subtle pill for inactive spaces

FONT="Hack Nerd Font"

sketchybar \
  --bar \
    height=36 \
    color=$BG \
    position=top \
    shadow=off \
    sticky=on \
    padding_right=18 \
    padding_left=18 \
  --default \
    icon.color=$FG \
    label.color=$FG \
    icon.font="$FONT:Regular:14.0" \
    label.font="$FONT:Regular:13.0" \
    padding_left=3 \
    padding_right=3 \
    label.padding_left=4 \
    label.padding_right=4 \
    icon.padding_left=7 \
    icon.padding_right=7

# ── Spaces ────────────────────────────────────────────────
for i in $(seq 1 9); do
  sketchybar --add space space.$i left \
    --set space.$i \
      associated_space=$i \
      icon=$i \
      icon.font="$FONT:Bold:11.0" \
      icon.color=$GRAY \
      icon.highlight_color=0xff282828 \
      background.color=$SPACE_DIM \
      background.highlight_color=0xfffabd2f \
      background.corner_radius=5 \
      background.height=22 \
      background.drawing=on \
      label.drawing=off \
      click_script="yabai -m space --focus $i 2>/dev/null"
done

# ── Battery ───────────────────────────────────────────────
sketchybar --add item battery right \
  --set battery \
    update_freq=60 \
    icon.font="$FONT:Regular:15.0" \
    label.font="$FONT:Regular:12.0" \
    padding_right=4 \
    script="$CONFIG_DIR/plugins/battery.sh"

# ── AirPods ───────────────────────────────────────────────
sketchybar --add item airpods right \
  --set airpods \
    update_freq=30 \
    drawing=off \
    icon.font="$FONT:Regular:14.0" \
    label.font="$FONT:Regular:12.0" \
    icon.color=$FG \
    label.color=$FG \
    script="$CONFIG_DIR/plugins/airpods.sh"

# ── Clock ─────────────────────────────────────────────────
sketchybar --add item clock right \
  --set clock \
    update_freq=30 \
    icon.drawing=off \
    label.color=$YELLOW \
    label.font="$FONT:Bold:13.0" \
    padding_left=6 \
    script="$CONFIG_DIR/plugins/clock.sh"

sketchybar --update
