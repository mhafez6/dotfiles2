#!/bin/bash

COLORS="$HOME/.local/share/tinted-theming/tinty/tinted-sketchybar-themes-file.sh"
[ -f "$COLORS" ] && source "$COLORS"

FONT="Hack Nerd Font"

sketchybar \
  --bar \
    height=37 \
    color=0x00000000 \
    position=top \
    shadow=off \
    sticky=on \
    margin=17 \
    y_offset=5 \
    corner_radius=9 \
    padding_right=2 \
    padding_left=2 \
  --default \
    icon.color=$SBAR_FG \
    label.color=$SBAR_FG \
    icon.font="$FONT:Regular:14.0" \
    label.font="$FONT:Regular:13.0" \
    padding_left=5 \
    padding_right=5 \
    icon.padding_left=5 \
    icon.padding_right=5 \
    label.padding_left=4 \
    label.padding_right=4 \
    background.height=28 \
    background.corner_radius=9 \
    background.border_width=1 \
    background.color=$SBAR_BG_ALT \
    background.border_color=$SBAR_BG_ALT \
    background.drawing=off

# в”Ђв”Ђ Spaces в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
for i in $(seq 1 9); do
  sketchybar --add space space.$i left \
    --set space.$i \
      associated_space=$i \
      icon=$i \
      icon.font="$FONT:Bold:12.0" \
      icon.color=$SBAR_FG \
      label.drawing=off \
      background.drawing=on \
      background.color=$SBAR_BG_ALT \
      background.border_color=$SBAR_BG_ALT \
      background.corner_radius=7 \
      background.height=26 \
      background.border_width=1 \
      padding_left=2 \
      padding_right=2 \
      click_script="yabai -m space --focus $i 2>/dev/null" \
      script="$CONFIG_DIR/plugins/space.sh"
done

# в”Ђв”Ђ Front App (center) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
sketchybar --add item front_app center \
  --set front_app \
    icon.drawing=off \
    label.font="$FONT:Bold:13.0" \
    label.color=$SBAR_FG \
    label.padding_left=10 \
    label.padding_right=10 \
    background.drawing=on \
    script="$CONFIG_DIR/plugins/front_app.sh" \
  --subscribe front_app front_app_switched

# в”Ђв”Ђ Volume в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
sketchybar --add item volume right \
  --set volume \
    icon.font="$FONT:Regular:14.0" \
    label.font="$FONT:Regular:13.0" \
    background.drawing=on \
    script="$CONFIG_DIR/plugins/volume.sh" \
  --subscribe volume volume_change

sketchybar --add item _sep1 right --set _sep1 width=6 background.drawing=off

# в”Ђв”Ђ Battery в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
sketchybar --add item battery right \
  --set battery \
    update_freq=60 \
    icon.font="$FONT:Regular:15.0" \
    label.font="$FONT:Regular:13.0" \
    background.drawing=on \
    script="$CONFIG_DIR/plugins/battery.sh"

# в”Ђв”Ђ AirPods в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
sketchybar --add item airpods right \
  --set airpods \
    update_freq=30 \
    drawing=off \
    icon.font="$FONT:Regular:14.0" \
    label.font="$FONT:Regular:13.0" \
    icon.color=$SBAR_FG \
    label.color=$SBAR_FG \
    background.drawing=on \
    script="$CONFIG_DIR/plugins/airpods.sh"

sketchybar --add item _sep2 right --set _sep2 width=6 background.drawing=off

# в”Ђв”Ђ Clock в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
sketchybar --add item clock right \
  --set clock \
    update_freq=30 \
    icon.drawing=off \
    label.color=$SBAR_YELLOW \
    label.font="$FONT:Bold:13.0" \
    label.padding_left=10 \
    label.padding_right=10 \
    background.drawing=on \
    script="$CONFIG_DIR/plugins/clock.sh"

sketchybar --update
