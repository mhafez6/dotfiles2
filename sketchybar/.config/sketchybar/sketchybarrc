#!/bin/bash

# ── Load tinty-generated base16 colors ───────────────────
COLORS="$HOME/.local/share/tinted-theming/tinty/tinted-sketchybar-themes-file.sh"
[ -f "$COLORS" ] && source "$COLORS"

FONT="Hack Nerd Font"

# inactive space pill: base01 at ~20% opacity
SPACE_INACTIVE="0x22${SBAR_BG_ALT:4}"

sketchybar \
  --bar \
    height=36 \
    color=$SBAR_BG \
    position=top \
    shadow=off \
    sticky=on \
    padding_right=18 \
    padding_left=18 \
  --default \
    icon.color=$SBAR_FG \
    label.color=$SBAR_FG \
    icon.font="$FONT:Regular:14.0" \
    label.font="$FONT:Regular:13.0" \
    padding_left=3 \
    padding_right=3 \
    label.padding_left=4 \
    label.padding_right=4 \
    icon.padding_left=7 \
    icon.padding_right=7

# ── Spaces ────────────────────────────────────────────────
for i in $(seq 1 9); do
  sketchybar --add space space.$i left \
    --set space.$i \
      associated_space=$i \
      icon=$i \
      icon.font="$FONT:Bold:11.0" \
      icon.color=$SBAR_DIM \
      icon.highlight_color=$SBAR_BG \
      background.color=$SPACE_INACTIVE \
      background.highlight_color=$SBAR_YELLOW \
      background.corner_radius=5 \
      background.height=22 \
      background.drawing=on \
      label.drawing=off \
      click_script="yabai -m space --focus $i 2>/dev/null"
done

# ── Battery ───────────────────────────────────────────────
sketchybar --add item battery right \
  --set battery \
    update_freq=60 \
    icon.font="$FONT:Regular:15.0" \
    label.font="$FONT:Regular:12.0" \
    padding_right=4 \
    script="$CONFIG_DIR/plugins/battery.sh"

# ── AirPods ───────────────────────────────────────────────
sketchybar --add item airpods right \
  --set airpods \
    update_freq=30 \
    drawing=off \
    icon.font="$FONT:Regular:14.0" \
    label.font="$FONT:Regular:12.0" \
    icon.color=$SBAR_FG \
    label.color=$SBAR_FG \
    script="$CONFIG_DIR/plugins/airpods.sh"

# ── Clock ─────────────────────────────────────────────────
sketchybar --add item clock right \
  --set clock \
    update_freq=30 \
    icon.drawing=off \
    label.color=$SBAR_YELLOW \
    label.font="$FONT:Bold:13.0" \
    padding_left=6 \
    script="$CONFIG_DIR/plugins/clock.sh"

sketchybar --update
