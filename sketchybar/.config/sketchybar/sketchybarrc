#!/bin/bash

# в”Ђв”Ђ Gruvbox Dark palette в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
BG=0xff282828
FG=0xffebdbb2
YELLOW=0xffd79921
GRAY=0xff928374
DIM_BG=0x553c3836

sketchybar \
  --bar \
    height=36 \
    color=$BG \
    position=top \
    shadow=off \
    sticky=on \
    padding_right=16 \
    padding_left=16 \
  --default \
    icon.color=$FG \
    label.color=$FG \
    icon.font="SF Pro:Regular:14.0" \
    label.font="SF Pro:Regular:13.0" \
    padding_left=4 \
    padding_right=4 \
    label.padding_left=4 \
    label.padding_right=4 \
    icon.padding_left=4 \
    icon.padding_right=4

# в”Ђв”Ђ Spaces (left) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
for i in $(seq 1 9); do
  sketchybar --add space space.$i left \
    --set space.$i \
      associated_space=$i \
      icon=$i \
      icon.color=$GRAY \
      icon.highlight_color=$YELLOW \
      icon.font="SF Pro:Bold:12.0" \
      background.color=$DIM_BG \
      background.corner_radius=5 \
      background.height=22 \
      background.drawing=on \
      label.drawing=off \
      click_script="yabai -m space --focus $i 2>/dev/null"
done

# в”Ђв”Ђ AirPods (right, hidden when disconnected) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
sketchybar --add item airpods right \
  --set airpods \
    update_freq=30 \
    drawing=off \
    label.color=$FG \
    icon.drawing=off \
    script="$CONFIG_DIR/plugins/airpods.sh"

# в”Ђв”Ђ Clock (right) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
sketchybar --add item clock right \
  --set clock \
    update_freq=30 \
    icon.drawing=off \
    label.color=$YELLOW \
    label.font="SF Pro:Semibold:13.0" \
    script="$CONFIG_DIR/plugins/clock.sh"

sketchybar --update
